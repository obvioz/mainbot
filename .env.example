TELEGRAM_BOT_TOKEN=put_your_telegram_bot_token_here
TELEGRAM_ALLOWED_USER_ID=put_your_telegram_user_id_here
EXCHANGE_ID=bybit
QUOTE=USDT
CAPITAL_USDT=1000
SCAN_INTERVAL_MINUTES=15
AUTO_MONITOR_ENABLED=true

# Optional: Bybit read-only API for portfolio sync
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_SYNC_ENABLED=false

BYBIT_PORTFOLIO_MONITOR_ENABLED=true
BYBIT_PORTFOLIO_MONITOR_MINUTES=5
BYBIT_DEEP_SYNC_MINUTES=30
BYBIT_RECV_WINDOW=30000
BYBIT_TIME_SAFETY_MS=1500

# Strategy bootstrap: automatically runs robust 5y if params are missing/stale
AUTO_STRATEGY_BOOTSTRAP_ENABLED=true
STRATEGY_BOOTSTRAP_MAX_AGE_DAYS=7

# v25 Performance / Market Memory
MARKET_CACHE_TTL_SECONDS=60
MARKET_CONTEXT_CACHE_TTL_SECONDS=180
SAVE_MARKET_SNAPSHOTS=true
